# "server" (default) uses Qdrant/Neo4j/Postgres below. "local" runs
# zero-service: writes to LOCAL_DATA_DIR via qdrant-client's embedded mode +
# SQLite, and ignores QDRANT_URL/NEO4J_*/USAGE_DB_* entirely.
DEPLOY_MODE=server
LOCAL_DATA_DIR=./graphtr-out
QDRANT_URL=http://localhost:6333
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
REASONING_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
SEARXNG_URL=http://localhost:8888
BROWSER_SERVICE_URL=http://localhost:8090
RAG_PORT=8030
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
# Required — docker-compose.yml has no weak default; set a real secret.
NEO4J_PASSWORD=
CODE_REPOS_DIR=./repos
# Preferred: separate host/port/user/password/name — assembled + URL-encoded in
# Python, so a password with special characters (@, :, /) works correctly.
USAGE_DB_HOST=localhost
USAGE_DB_PORT=5432
USAGE_DB_USER=lmr
# Required — docker-compose.yml has no weak default; set a real secret.
USAGE_DB_PASSWORD=
USAGE_DB_NAME=hoton_rag
# Fallback: a pre-built URL (only used if USAGE_DB_HOST is unset). If your
# password has special characters, they must already be percent-encoded here.
USAGE_DB_URL=
# Optional -- but leaving either blank means /dashboard and
# /api/dashboard/summary serve with NO auth (fail-open), exposing usage
# stats/health/per-user breakdown to anyone who can reach this port. Set both
# to require login.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
